  #set text(size: 8.0pt)
  #set par(first-line-indent: 0pt, justify: false, leading: 0.28em)
  #table(
    columns: (1fr, 1fr, 1fr),
    stroke: 0.35pt + luma(170),
    inset: 4pt,
    table.header(
      table.cell(align: center + horizon, fill: luma(235))[*Исходное изображение*],
      table.cell(align: center + horizon, fill: luma(235))[*Лето*],
