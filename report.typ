    ),
    table.cell(align: center + horizon)[#image("report_assets/season_source.png", width: 100%)],
    table.cell(align: center + horizon)[#image("report_assets/season_summer.png", width: 100%)],
    table.cell(align: center + horizon)[#image("report_assets/season_winter.png", width: 100%)],
  )
]

#block(width: 100%)[
  #set text(size: 8.0pt)
  #set par(first-line-indent: 0pt, justify: false, leading: 0.28em)
  #table(
